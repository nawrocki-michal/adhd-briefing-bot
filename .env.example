# Telegram bot token z @BotFather
TELEGRAM_BOT_TOKEN=

# Klucz Claude API (https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Ścieżka do bazy SQLite
DB_PATH=adhd.db

# Domyślna strefa czasowa dla schedulera
DEFAULT_TIMEZONE=Europe/Warsaw

# Maksymalna liczba artykułów per briefing (ADHD-friendly)
BRIEFING_MAX_ARTICLES=5

# Model Claude do streszczeń
SUMMARIZER_MODEL=claude-haiku-4-5-20251001

# Limit równoczesnych wywołań LLM (rate limiting)
LLM_CONCURRENCY=3
